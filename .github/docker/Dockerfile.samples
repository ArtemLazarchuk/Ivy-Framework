# Dockerfile.samples — used in ivy-examples to deploy samples preview from PRs.

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS base
USER $APP_UID
WORKDIR /app
EXPOSE 5010
# Speeds up JIT for responsive spin-up
ENV DOTNET_TieredPGO=1
ENV DOTNET_TC_QuickJitForLoops=1

# Build frontend (Ivy embeds frontend/dist)
FROM node:24-bookworm-slim AS frontend
WORKDIR /src
# Cache npm layers
RUN --mount=type=cache,id=apt-samples-frontend,target=/var/cache/apt \
    apt-get update && apt-get install -y curl bash && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL https://vite.plus | bash
ENV PATH="/root/.vite-plus/bin:${PATH}"
COPY ["src/frontend/package.json", "src/frontend/pnpm-lock.yaml", "src/frontend/"]
# Cache vp install layer
RUN --mount=type=cache,target=/root/.npm \
    cd src/frontend && vp install
COPY ["src/frontend/", "src/frontend/"]
RUN cd src/frontend && vp build

# Build .NET from source (no IVY_PACKAGE_VERSION = use ProjectReference, your changes apply)
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
ARG BUILD_CONFIGURATION=Release
ARG TARGETARCH
WORKDIR /src
RUN --mount=type=cache,id=apt-samples-build,target=/var/cache/apt \
    apt-get update && apt-get install -y curl bash build-essential && rm -rf /var/lib/apt/lists/*
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | bash -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && apt-get install -y nodejs
RUN curl -fsSL https://vite.plus | bash
ENV PATH="/root/.vite-plus/bin:${PATH}"

COPY . .
COPY --from=frontend /src/src/frontend/dist /src/src/frontend/dist

# Use BuildKit mounts to cache crates and packages across builds
RUN --mount=type=cache,target=/root/.cargo/registry \
    cd src/RustServer && cargo build --release

RUN --mount=type=cache,target=/root/.nuget/packages \
    dotnet restore "src/Ivy.Samples/Ivy.Samples.csproj"

# Publish with ReadyToRun to pre-compile IL to native code for instant container spin-up
RUN --mount=type=cache,target=/root/.nuget/packages \
    dotnet publish "src/Ivy.Samples/Ivy.Samples.csproj" \
    -a ${TARGETARCH:-x64} \
    -c $BUILD_CONFIGURATION \
    -o /app/publish \
    /p:UseAppHost=false \
    /p:PublishReadyToRun=true

FROM base AS final
WORKDIR /app
ENV PORT=5010
COPY --from=build /app/deploy .
ENTRYPOINT ["dotnet", "Ivy.Samples.dll"]